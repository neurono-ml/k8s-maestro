// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/rust
{
	"name": "Rust",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/rust:2-1-trixie",
	"features": {
		"ghcr.io/stu-bell/devcontainer-features/claude-code:0": {},
		"ghcr.io/stu-bell/devcontainer-features/node:0": {},
		"ghcr.io/rio/features/k3d:1": {},
		"ghcr.io/jsburckhardt/devcontainer-features/opencode:1": {},
		"ghcr.io/va-h/devcontainers-features/uv:1": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/eitsupi/devcontainer-features/mdbook:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [			
				"tamasfe.even-better-toml",
				"Anthropic.claude-code",
				"mtxr.sqltools",
				"sst-dev.opencode",
				"Codder13.openspec"
			],
			"settings": {
				"editor.formatOnSave": false,
				"files.autoSave": "afterDelay"
			}
		}
	},
	"mounts": [
		"source=${localEnv:HOME}/.ssh/,target=/home/vscode/.ssh/,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.aws,target=/home/vscode/.aws,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.claude/settings.json.eb.glm,target=/home/vscode/.claude/settings.json,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.config/opencode,target=/home/vscode/.config/opencode/,type=bind,consistency=cached",
		"source=${localEnv:HOME}/.local/share/opencode,target=/home/vscode/.local/share/opencode/,type=bind,consistency=cached"
	],
	"postCreateCommand": ".devcontainer/setup.sh"
	
}
